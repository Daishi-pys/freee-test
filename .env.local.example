# freee API（https://developer.freee.co.jp でアプリ登録して取得）
FREEE_CLIENT_ID=your_client_id_here
FREEE_CLIENT_SECRET=your_client_secret_here

# アプリのURL（ローカルは http://localhost:3000）
NEXTAUTH_URL=http://localhost:3000

# セッション暗号化キー（openssl rand -base64 32 で生成）
NEXTAUTH_SECRET=your_secret_here

# freee OAuthコールバックURL（freeeアプリ設定に登録する）
# http://localhost:3000/api/auth/callback/freee
